      "resourceTypes": ["AllergyIntolerance", "CarePlan", "CareTeam", "Condition", "Device", "DiagnosticReport", "DocumentReference", "Encounter", "Immunization", "Location", "Medication", "MedicationRequest", "MedicationAdministration", "Observation", "Organization", "Patient", "Procedure", "Practitioner", "PractitionerRole", "Provenance", "SupplyDelivery"]
    },
    "defaults": {
