        "paperTextColor": "rgba(0, 0, 0, 1) !important",
      
        "backgroundCanvas": "#e6e6e6",
        "background": "linear-gradient(45deg, rgb(108, 183, 110) 30%, rgb(150, 202, 144) 90%)",

        "nivoTheme": "red_grey"
      }
    },
    "loggingThreshold": "debug",
    "fhirAutoSubscribe": true,
