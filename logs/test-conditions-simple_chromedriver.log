   "script": "var passedArgs = Array.prototype.slice.call(arguments,0); return (function() {\n        // Ensure we're logged in\n        if (!Meteor.userId()) {\n          Meteor.loginWithPassword('janedoe', 'janedoe123');\n        }\n        \n        // Check if Conditions exists\n        if (typeof Conditions === 'undefined') {\n          return { error: 'Conditions collection not found' };\n        }\n        \n        // Count existing conditions\n        const beforeCount = Conditions.find({}).count();\n        \n        // Create a very simple condition\n        const simpleCondition = {\n          resourceType: 'Condition',\n          code: { \n            text: 'Simple Test Condition'\n          }\n        };\n        \n        const id = Conditions.insert(simpleCondition);\n        \n        // Count after insert\n        const afterCount = Conditions.find({}).count();\n        \n        // Fetch the condition we just created\n        const inserted = Conditions.findOne(id);\n        \n        return {\n          beforeCount: beforeCount,\n          afterCount: afterCount,\n          insertedId: id,\n          inserted: inserted,\n          collectionExists: true\n        };\n      }).apply(window, passedArgs);"
}
