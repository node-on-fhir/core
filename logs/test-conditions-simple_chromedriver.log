   "script": "var passedArgs = Array.prototype.slice.call(arguments,0); return (function() {\n      const table = document.querySelector('#conditionsTable');\n      const pageElement = document.querySelector('#conditionsPage');\n      \n      if (!table) {\n        return { \n          hasTable: false,\n          pageExists: !!pageElement,\n          pageContent: pageElement ? pageElement.textContent : 'No page element'\n        };\n      }\n      \n      const rows = table.querySelectorAll('tbody tr');\n      const rowData = [];\n      \n      rows.forEach((row, index) => {\n        const cells = row.querySelectorAll('td');\n        const cellTexts = [];\n        cells.forEach(cell => {\n          cellTexts.push(cell.textContent.trim());\n        });\n        rowData.push({\n          index: index,\n          cellCount: cells.length,\n          cellTexts: cellTexts\n        });\n      });\n      \n      return {\n        hasTable: true,\n        rowCount: rows.length,\n        rowData: rowData\n      };\n    }).apply(window, passedArgs);"
}
