   "script": "var passedArgs = Array.prototype.slice.call(arguments,0); return (function() {\n      const table = document.querySelector('#conditionsTable');\n      if (!table) return { hasTable: false };\n      \n      const rows = table.querySelectorAll('tbody tr');\n      const asserters = [];\n      \n      // First let's check what columns are visible\n      const headerCells = table.querySelectorAll('thead tr th');\n      const columnHeaders = [];\n      headerCells.forEach((cell, index) => {\n        columnHeaders.push({ index: index + 1, text: cell.textContent.trim() });\n      });\n      \n      // Find the asserter column position\n      let asserterColumnIndex = -1;\n      columnHeaders.forEach(header => {\n        if (header.text === 'Asserter' || header.text.includes('Asserter')) {\n          asserterColumnIndex = header.index;\n        }\n      });\n      \n      // Also check if the table has any rows with test conditions\n      let testConditionRows = [];\n      \n      rows.forEach((row, rowIndex) => {\n        const cells = row.querySelectorAll('td');\n        let rowText = '';\n        cells.forEach(cell => {\n          rowText += cell.textContent.trim() + ' | ';\n        });\n        \n        // Check if this row contains our test conditions\n        if (rowText.includes('First') || rowText.includes('Second') || rowText.includes('Third') ||\n            rowText.includes('Dr. Smith') || rowText.includes('Dr. Johnson') || rowText.includes('Dr. Williams')) {\n          testConditionRows.push({ index: rowIndex, text: rowText });\n        }\n        \n        if (asserterColumnIndex > 0) {\n          const asserterCell = row.querySelector(`td:nth-child(${asserterColumnIndex})`);\n          if (asserterCell) {\n            asserters.push(asserterCell.textContent.trim());\n          }\n        }\n      });\n      \n      return {\n        hasTable: true,\n        rowCount: rows.length,\n        columnHeaders: columnHeaders,\n        asserterColumnIndex: asserterColumnIndex,\n        asserters: asserters,\n        testConditionRows: testConditionRows,\n        firstAsserter: asserters[0] || null,\n        lastAsserter: asserters[asserters.length - 1] || null\n      };\n    }).apply(window, passedArgs);"
}
