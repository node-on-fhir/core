   "script": "var passedArgs = Array.prototype.slice.call(arguments,0); return (function() {\n        // Ensure we're logged in\n        if (!Meteor.userId()) {\n          Meteor.loginWithPassword('janedoe', 'janedoe123');\n        }\n        \n        // Wait for Conditions collection to be available\n        if (typeof Conditions === 'undefined' && window.Conditions) {\n          window.Conditions = window.Conditions;\n        }\n        \n        // Clear existing conditions for test user\n        if (typeof Conditions !== 'undefined') {\n          // Store the count before clearing\n          const existingCount = Conditions.find({}).count();\n          console.log('Existing conditions before test:', existingCount);\n          \n          // Remove only test conditions (with specific asserters)\n          Conditions.remove({ \n            'asserter.display': { \n              $in: ['Dr. Smith - First', 'Dr. Johnson - Second', 'Dr. Williams - Third'] \n            }\n          });\n          \n          // Create test conditions with different dates\n          const testConditions = [\n            {\n              id: 'test-condition-1',\n              resourceType: 'Condition',\n              code: { \n                coding: [{ code: '195967001', display: 'Asthma - Test 1' }],\n                text: 'Asthma - Test 1'\n              },\n              subject: { display: 'John Doe', reference: 'Patient/123' },\n              asserter: { display: 'Dr. Smith - First', reference: 'Practitioner/456' },\n              clinicalStatus: { coding: [{ code: 'active' }] },\n              verificationStatus: { coding: [{ code: 'confirmed' }] },\n              onsetDateTime: new Date('2023-01-01'),\n              recordedDate: new Date('2023-01-01'),\n              meta: { lastUpdated: new Date('2023-01-01') }\n            },\n            {\n              id: 'test-condition-2',\n              resourceType: 'Condition',\n              code: { \n                coding: [{ code: '195967001', display: 'Asthma - Test 2' }],\n                text: 'Asthma - Test 2'\n              },\n              subject: { display: 'John Doe', reference: 'Patient/123' },\n              asserter: { display: 'Dr. Johnson - Second', reference: 'Practitioner/789' },\n              clinicalStatus: { coding: [{ code: 'active' }] },\n              verificationStatus: { coding: [{ code: 'confirmed' }] },\n              onsetDateTime: new Date('2023-06-01'),\n              recordedDate: new Date('2023-06-01'),\n              meta: { lastUpdated: new Date('2023-06-01') }\n            },\n            {\n              id: 'test-condition-3',\n              resourceType: 'Condition',\n              code: { \n                coding: [{ code: '195967001', display: 'Asthma - Test 3' }],\n                text: 'Asthma - Test 3'\n              },\n              subject: { display: 'John Doe', reference: 'Patient/123' },\n              asserter: { display: 'Dr. Williams - Third', reference: 'Practitioner/321' },\n              clinicalStatus: { coding: [{ code: 'active' }] },\n              verificationStatus: { coding: [{ code: 'confirmed' }] },\n              onsetDateTime: new Date('2023-12-01'),\n              recordedDate: new Date('2023-12-01'),\n              meta: { lastUpdated: new Date('2023-12-01') }\n            }\n          ];\n          \n          let insertedIds = [];\n          testConditions.forEach(condition => {\n            const id = Conditions.insert(condition);\n            insertedIds.push(id);\n          });\n          \n          // Wait a moment for inserts to complete\n          const afterInsertCount = Conditions.find({}).count();\n          console.log('After insert, total conditions:', afterInsertCount);\n          console.log('Inserted IDs:', insertedIds);\n          \n          // Verify the test conditions were inserted\n          const testConditionCount = Conditions.find({ \n            'asserter.display': { \n              $in: ['Dr. Smith - First', 'Dr. Johnson - Second', 'Dr. Williams - Third'] \n            }\n          }).count();\n          console.log('Test conditions inserted:', testConditionCount);\n          \n          return { \n            success: true, \n            insertedCount: insertedIds.length,\n            totalCount: afterInsertCount,\n            testConditionCount: testConditionCount\n          };\n        }\n        return false;\n      }).apply(window, passedArgs);"
