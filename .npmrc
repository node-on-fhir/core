# Skip test-only browser-driver downloads during npm install.
# chromedriver@146 ships a broken install.js (compareVersions export shape) that
# crashes on macOS arm64 and aborts the whole install; the driver is a Nightwatch
# E2E tool, irrelevant to build/deploy. Real chromedriver is provided at test time.
chromedriver_skip_download=true
geckodriver_skip_download=true
puppeteer_skip_download=true
