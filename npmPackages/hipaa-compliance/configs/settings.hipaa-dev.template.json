{
  "public": {
    "title": "Honeycomb HIPAA",
    "defaults": {
      "route": "/hipaa/audit-log",
      "sidebar": {
        "menuItems": {
          "FhirResources": true,
          "HipaaAuditLog": true,
          "HipaaPolicies": true,
          "ComplianceReports": true,
          "SidebarWorkflows": true
        },
        "hidden": []
      }
    },
    "organization": {
      "name": "",
      "address": "",
      "privacyOfficer": "",
      "securityOfficer": "",
      "phone": "",
      "email": ""
    },
    "security": {
      "passwordMinLength": 12,
      "maxLoginAttempts": 5
    },
    "hipaa": {
      "features": {
        "auditLogging": true,
        "automaticHooks": true,
        "complianceReporting": true,
        "policyManagement": true,
        "dataExport": true,
        "encryptedExport": false,
        "integrityChecking": true
      },
      "security": {
        "requireSecondaryAuth": false,
        "authTimeoutMinutes": 30,
        "sessionTimeout": 30
      },
      "compliance": {
        "environment": "development",
        "auditDetailLevel": "standard",
        "dataRetentionYears": 7
      },
      "ui": {
        "defaultPageSize": 25
      },
      "policies": {
        "backupFrequency": "daily",
        "networkScanningSoftware": "[Network Scanning Software]"
      }
    }
  },
  "private": {
    "x509": {
      "privateKey": "",
      "certificate": "",
      "previousKeys": {}
    },
    "accounts": {
      "defaultRole": [
        "user",
        "patient"
      ]
    },
    "hipaa": {
      "audit": {
        "immutable": true
      },
      "security": {
        "encryptionLevel": "none",
        "allowDebugAccess": false
      },
      "encryption": {
        "algorithm": "aes-256-gcm",
        "keyRotationDays": 90,
        "lastKeyRotation": null
      },
      "hooks": {
        "enableCollectionHooks": true,
        "monitoredCollections": [
          "Patients",
          "Observations",
          "Encounters",
          "Conditions",
          "Procedures",
          "MedicationRequests",
          "DiagnosticReports",
          "CarePlans",
          "Goals"
        ],
        "excludeSystemUsers": [
          "system",
          "migration-user"
        ],
        "logReadAccess": false
      },
      "reporting": {
        "maxExportRecords": 10000,
        "requireApprovalForExport": false
      }
    }
  }
}
