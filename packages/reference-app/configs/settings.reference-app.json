{
  "public": {
    "title": "Honeycomb with Reference App",
    "version": "0.1.0",
    "fhirVersion": "4.0.1",
    "defaults": {
      "route": "/reference-app",
      "landingPage": "/reference-app",
      "dateFormat": "YYYY-MM-DD", 
      "dateTimeFormat": "YYYY-MM-DD HH:mm:ss",
      "disableHeader": false,
      "disableFooter": false,
      "paginationLimit": 100,
      "subscriptionLimit": 1000
    },
    "interfaces": {
      "fhir": {
        "channel": {
          "name": "Clinical Channel",
          "endpoint": "https://localhost:3000/baseR4",
          "version": "4.0.1"
        }
      }
    },
    "modules": {
      "referenceApp": {
        "enabled": true,
        "showInSidebar": true,
        "showInWorkflows": true,
        "requireAuthentication": true,
        "allowedRoles": ["practitioner", "admin", "user"],
        "features": {
          "workflow": true,
          "dataCollection": true,
          "reporting": true,
          "export": true
        },
        "ui": {
          "showHeader": true,
          "showTabs": true,
          "showFooterButtons": true,
          "theme": "default"
        }
      }
    }
  },
  "private": {
    "referenceApp": {
      "apiKey": "REPLACE_WITH_YOUR_API_KEY",
      "apiSecret": "REPLACE_WITH_YOUR_API_SECRET",
      "endpoint": "https://api.example.com/v1",
      "timeout": 30000,
      "retryAttempts": 3,
      "enableCronJobs": false,
      "cronSchedule": "every 24 hours",
      "initializeSampleData": false,
      "debugMode": false,
      "logging": {
        "enabled": true,
        "level": "info",
        "includeMetadata": true
      },
      "validation": {
        "strict": true,
        "allowPartialResources": false,
        "validateOnSave": true
      },
      "integration": {
        "externalSystemUrl": "",
        "authType": "oauth2",
        "clientId": "",
        "clientSecret": "",
        "scope": "patient/*.read"
      }
    },
    "enableTaskManager": false,
    "enableCronAutomation": false
  }
}