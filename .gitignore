._*

node_modules/

*.galaxy.*
version.desktop

.desktop
.desktop/*

logs
logs/*

test
tests_output
tests/output
tests/screenshots
tests/nightwatch/screenshots
tests_output

# npmPackages/* and core/* are tracked in this monorepo — npmPackages is the
# workflow-package home (the old packages/ Atmosphere dir is retired to deprecated/).
#
# extensions/* are private/user-defined packages, each with its own nested git
# repo — ignore their contents, keep only the directory-level CLAUDE.md stub so
# the directory stays in the tree. Nothing under extensions/ is checked into this
# monorepo.
extensions/*
!extensions/CLAUDE.md

# Retired Atmosphere packages parked post-migration (each keeps its own nested git repo)
deprecated/

.DS_Store

# Environment files (contain secrets)
.env
.env.*
!.env.*.example

.meteor/packages

settings.*.json
# ...but tracked secret-free templates (*.template.json) ship with their package.
# These MUST contain no real secrets — secret values are empty, filled via env or a
# local (gitignored) settings.*.json copy at runtime.
!settings.*.template.json

screenshots/*
screenshots/*/*

scrap
workzone
fable

proprietary
contracted

# Meteor Modern-Tools build context directories
_build
*/build-assets
*/build-chunks
.rsdoctor

# Auto-generated workflow barrels (generated by rspack.workflowParser.js)
imports/workflows/index.js
imports/workflows/loader.js
imports/workflows/server-loader.js

# Auto-generated workflow assets (copied by rspack.workflowParser.js)
public/workflows/

# CesiumJS static assets (copied by scripts/copy-cesium-assets.js)
public/cesium/


# Ralph loop ephemeral state
.claude/ralph-loop.local.md

# Machine-generated artifacts
graphify-out/
.playwright-mcp/
libraries/
