{
  "public": {
    "title": "Honeycomb - Clinical Documents",
    "defaults": {
      "route": "/clinical-documents",
      "landingPage": "/clinical-documents",
      "dateFormat": "YYYY-MM-DD",
      "tableRowSize": "normal"
    },
    "clinicalDocuments": {
      "enabled": true,
      "showInSidebar": true,
      "defaultView": "list",
      "allowDocumentUpload": true,
      "allowDocumentCreation": true,
      "supportedDocumentTypes": [
        "Discharge Summary",
        "Progress Note", 
        "History and Physical",
        "Consultation Note",
        "Operative Note",
        "Procedure Note",
        "Imaging Report",
        "Laboratory Report",
        "Pathology Report"
      ],
      "features": {
        "versioning": true,
        "attestation": true,
        "amendments": true,
        "cdaImport": false,
        "cdaExport": false
      }
    },
    "modules": {
      "fhir": {
        "ClinicalDocument": {
          "enabled": true,
          "route": "/clinical-documents",
          "primaryColor": "#4A90E2",
          "iconName": "DocumentText"
        }
      }
    }
  },
  "private": {
    "clinicalDocuments": {
      "autoSaveInterval": 30000,
      "maxDocumentSize": 10485760,
      "allowedFileTypes": [
        "application/pdf",
        "text/plain",
        "text/html",
        "application/xml",
        "application/hl7-v3+xml"
      ]
    }
  }
}