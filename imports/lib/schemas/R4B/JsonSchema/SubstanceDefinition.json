{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/SubstanceDefinition",
  "description": "The detailed description of a substance, typically at a level beyond what is used for prescribing.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "SubstanceDefinition" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "status": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "classification": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "domain": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "grade": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "description": { "type": "string" },
    "informationSource": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } },
    "manufacturer": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "supplier": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "moiety": { "type": "array", "items": { "type": "object", "properties": { "role": { "type": "object" }, "identifier": { "type": "object" }, "name": { "type": "string" }, "stereochemistry": { "type": "object" }, "opticalActivity": { "type": "object" }, "molecularFormula": { "type": "string" }, "amountQuantity": { "type": "object" }, "amountString": { "type": "string" }, "measurementType": { "type": "object" } } } },
    "property": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "valueCodeableConcept": { "type": "object" }, "valueQuantity": { "type": "object" }, "valueDate": { "type": "string" }, "valueBoolean": { "type": "boolean" }, "valueAttachment": { "type": "object" } } } },
    "molecularWeight": { "type": "array", "items": { "type": "object", "properties": { "method": { "type": "object" }, "type": { "type": "object" }, "amount": { "type": "object" } } } },
    "structure": { "type": "object", "properties": { "stereochemistry": { "type": "object" }, "opticalActivity": { "type": "object" }, "molecularFormula": { "type": "string" }, "molecularFormulaByMoiety": { "type": "string" }, "sourceDocument": { "type": "array", "items": { "type": "object" } }, "representation": { "type": "array", "items": { "type": "object" } } } },
    "code": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object" }, "status": { "type": "object" }, "statusDate": { "type": "string" }, "note": { "type": "array", "items": { "type": "object" } }, "source": { "type": "array", "items": { "type": "object" } } } } },
    "name": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "object" }, "status": { "type": "object" }, "preferred": { "type": "boolean" }, "language": { "type": "array", "items": { "type": "object" } }, "domain": { "type": "array", "items": { "type": "object" } }, "jurisdiction": { "type": "array", "items": { "type": "object" } }, "synonym": { "type": "array", "items": { "type": "object" } }, "translation": { "type": "array", "items": { "type": "object" } }, "official": { "type": "array", "items": { "type": "object" } }, "source": { "type": "array", "items": { "type": "object" } } } } },
    "relationship": { "type": "array", "items": { "type": "object", "properties": { "substanceDefinitionReference": { "type": "object" }, "substanceDefinitionCodeableConcept": { "type": "object" }, "type": { "type": "object" }, "isDefining": { "type": "boolean" }, "amountQuantity": { "type": "object" }, "amountRatio": { "type": "object" }, "amountString": { "type": "string" }, "ratioHighLimitAmount": { "type": "object" }, "comparator": { "type": "object" }, "source": { "type": "array", "items": { "type": "object" } } } } },
    "sourceMaterial": { "type": "object", "properties": { "type": { "type": "object" }, "genus": { "type": "object" }, "species": { "type": "object" }, "part": { "type": "object" }, "countryOfOrigin": { "type": "array", "items": { "type": "object" } } } }
  }
}
