{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/CoverageEligibilityRequest",
  "description": "The CoverageEligibilityRequest provides patient and insurance coverage information to an insurer for them to respond, in the form of an CoverageEligibilityResponse, with information regarding whether the stated coverage is valid and in-force and optionally to provide the insurance details of the policy.",
  "type": "object",
  "required": ["resourceType", "status", "purpose", "patient", "created", "insurer"],
  "properties": {
    "resourceType": { "const": "CoverageEligibilityRequest" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "status": { "type": "string", "enum": ["active", "cancelled", "draft", "entered-in-error"] },
    "priority": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "purpose": { "type": "array", "items": { "type": "string", "enum": ["auth-requirements", "benefits", "discovery", "validation"] } },
    "patient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "servicedDate": { "type": "string" },
    "servicedPeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "created": { "type": "string" },
    "enterer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "provider": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "insurer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "facility": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "supportingInfo": { "type": "array", "items": { "type": "object", "properties": { "sequence": { "type": "integer" }, "information": { "type": "object" }, "appliesToAll": { "type": "boolean" } } } },
    "insurance": { "type": "array", "items": { "type": "object", "properties": { "focal": { "type": "boolean" }, "coverage": { "type": "object" }, "businessArrangement": { "type": "string" } } } },
    "item": { "type": "array", "items": { "type": "object", "properties": { "supportingInfoSequence": { "type": "array", "items": { "type": "integer" } }, "category": { "type": "object" }, "productOrService": { "type": "object" }, "modifier": { "type": "array", "items": { "type": "object" } }, "provider": { "type": "object" }, "quantity": { "type": "object" }, "unitPrice": { "type": "object" }, "facility": { "type": "object" }, "diagnosis": { "type": "array", "items": { "type": "object" } }, "detail": { "type": "array", "items": { "type": "object" } } } } }
  }
}
