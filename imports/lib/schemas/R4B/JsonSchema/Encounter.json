tem": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } } },
    "location": { "type": "array", "items": { "type": "object", "properties": { "location": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "status": { "type": "string", "enum": ["planned", "active", "reserved", "completed"] }, "physicalType": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "period": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } } } } },
