    "eventsSinceSubscriptionStart": { "type": "string" },
    "notificationEvent": { "type": "array", "items": { "type": "object", "properties": { "eventNumber": { "type": "string" }, "timestamp": { "type": "string" }, "focus": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "additionalContext": { "type": "array", "items": { "type": "object" } } } } },
    "subscription": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "topic": { "type": "string" },
    "error": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } }
  }
