{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/PaymentReconciliation",
  "description": "This resource provides the details including amount of a payment and allocates the payment items being paid.",
  "type": "object",
  "required": ["resourceType", "status", "created", "paymentDate", "paymentAmount"],
  "properties": {
    "resourceType": { "const": "PaymentReconciliation" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "status": { "type": "string", "enum": ["active", "cancelled", "draft", "entered-in-error"] },
    "period": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "created": { "type": "string" },
    "paymentIssuer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "request": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "requestor": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "outcome": { "type": "string", "enum": ["queued", "complete", "error", "partial"] },
    "disposition": { "type": "string" },
    "paymentDate": { "type": "string" },
    "paymentAmount": { "type": "object", "properties": { "value": { "type": "number" }, "currency": { "type": "string" } } },
    "paymentIdentifier": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } },
    "detail": { "type": "array", "items": { "type": "object", "properties": { "identifier": { "type": "object" }, "predecessor": { "type": "object" }, "type": { "type": "object" }, "request": { "type": "object" }, "submitter": { "type": "object" }, "response": { "type": "object" }, "date": { "type": "string" }, "responsible": { "type": "object" }, "payee": { "type": "object" }, "amount": { "type": "object" } } } },
    "formCode": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "processNote": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["display", "print", "printoper"] }, "text": { "type": "string" } } } }
  }
}
