{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/RequestGroup",
  "description": "A group of related requests that can be used to capture intended activities that have inter-dependencies such as 'give this medication after that one'.",
  "type": "object",
  "required": ["resourceType", "status", "intent"],
  "properties": {
    "resourceType": { "const": "RequestGroup" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "instantiatesCanonical": { "type": "array", "items": { "type": "string" } },
    "instantiatesUri": { "type": "array", "items": { "type": "string" } },
    "basedOn": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "replaces": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "groupIdentifier": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } },
    "status": { "type": "string", "enum": ["draft", "active", "on-hold", "revoked", "completed", "entered-in-error", "unknown"] },
    "intent": { "type": "string", "enum": ["proposal", "plan", "directive", "order", "original-order", "reflex-order", "filler-order", "instance-order", "option"] },
    "priority": { "type": "string", "enum": ["routine", "urgent", "asap", "stat"] },
    "code": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "subject": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "encounter": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "authoredOn": { "type": "string" },
    "author": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "reasonCode": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "reasonReference": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } },
    "action": { "type": "array", "items": { "type": "object", "properties": { "prefix": { "type": "string" }, "title": { "type": "string" }, "description": { "type": "string" }, "textEquivalent": { "type": "string" }, "priority": { "type": "string", "enum": ["routine", "urgent", "asap", "stat"] }, "code": { "type": "array", "items": { "type": "object" } }, "documentation": { "type": "array", "items": { "type": "object" } }, "condition": { "type": "array", "items": { "type": "object", "properties": { "kind": { "type": "string", "enum": ["applicability", "start", "stop"] }, "expression": { "type": "object" } } } }, "relatedAction": { "type": "array", "items": { "type": "object", "properties": { "actionId": { "type": "string" }, "relationship": { "type": "string" }, "offsetDuration": { "type": "object" }, "offsetRange": { "type": "object" } } } }, "timingDateTime": { "type": "string" }, "timingAge": { "type": "object" }, "timingPeriod": { "type": "object" }, "timingDuration": { "type": "object" }, "timingRange": { "type": "object" }, "timingTiming": { "type": "object" }, "participant": { "type": "array", "items": { "type": "object" } }, "type": { "type": "object" }, "groupingBehavior": { "type": "string" }, "selectionBehavior": { "type": "string" }, "requiredBehavior": { "type": "string" }, "precheckBehavior": { "type": "string" }, "cardinalityBehavior": { "type": "string" }, "resource": { "type": "object" }, "action": { "type": "array", "items": { "type": "object" } } } } }
  }
}
