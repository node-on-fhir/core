{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/Contract",
  "description": "Legally enforceable, formally recorded unilateral or bilateral directive i.e., a policy or agreement.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "Contract" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "url": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["amended", "appended", "cancelled", "disputed", "entered-in-error", "executable", "executed", "negotiable", "offered", "policy", "rejected", "renewed", "revoked", "resolved", "terminated"] },
    "legalState": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "instantiatesCanonical": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "instantiatesUri": { "type": "string" },
    "contentDerivative": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "issued": { "type": "string" },
    "applies": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "expirationType": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "subject": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "authority": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "domain": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "site": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "alias": { "type": "array", "items": { "type": "string" } },
    "author": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "scope": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "topicCodeableConcept": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "topicReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "subType": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "contentDefinition": { "type": "object", "properties": { "type": { "type": "object" }, "subType": { "type": "object" }, "publisher": { "type": "object" }, "publicationDate": { "type": "string" }, "publicationStatus": { "type": "string" }, "copyright": { "type": "string" } } },
    "term": { "type": "array", "items": { "type": "object" } },
    "supportingInfo": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "relevantHistory": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "signer": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "party": { "type": "object" }, "signature": { "type": "array", "items": { "type": "object" } } } } },
    "friendly": { "type": "array", "items": { "type": "object", "properties": { "contentAttachment": { "type": "object" }, "contentReference": { "type": "object" } } } },
    "legal": { "type": "array", "items": { "type": "object", "properties": { "contentAttachment": { "type": "object" }, "contentReference": { "type": "object" } } } },
    "rule": { "type": "array", "items": { "type": "object", "properties": { "contentAttachment": { "type": "object" }, "contentReference": { "type": "object" } } } },
    "legallyBindingAttachment": { "type": "object" },
    "legallyBindingReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }
  }
}
