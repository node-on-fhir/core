{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/Evidence",
  "description": "The Evidence Resource provides a machine-interpretable expression of an evidence concept including the evidence variables, the statistics, and the certainty of this evidence.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "Evidence" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "citeAsReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "citeAsMarkdown": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "date": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "approvalDate": { "type": "string" },
    "lastReviewDate": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } } } } },
    "author": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "editor": { "type": "array", "items": { "type": "object" } },
    "reviewer": { "type": "array", "items": { "type": "object" } },
    "endorser": { "type": "array", "items": { "type": "object" } },
    "relatedArtifact": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string" }, "label": { "type": "string" }, "display": { "type": "string" }, "citation": { "type": "string" }, "url": { "type": "string" }, "document": { "type": "object" }, "resource": { "type": "string" } } } },
    "description": { "type": "string" },
    "assertion": { "type": "string" },
    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } },
    "variableDefinition": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "note": { "type": "array", "items": { "type": "object" } }, "variableRole": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "observed": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "intended": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "directnessMatch": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } } } },
    "synthesisType": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "studyType": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "statistic": { "type": "array", "items": { "type": "object" } },
    "certainty": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "note": { "type": "array", "items": { "type": "object" } }, "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "rating": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "rater": { "type": "string" }, "subcomponent": { "type": "array", "items": { "type": "object" } } } } }
  }
}
