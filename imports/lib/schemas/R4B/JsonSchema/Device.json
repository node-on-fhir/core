{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/Device",
  "description": "A type of a manufactured item that is used in the provision of healthcare without being substantially changed through that activity. The device may be a medical or non-medical device.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "Device" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "definition": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "udiCarrier": { "type": "array", "items": { "type": "object", "properties": { "deviceIdentifier": { "type": "string" }, "issuer": { "type": "string" }, "jurisdiction": { "type": "string" }, "carrierAIDC": { "type": "string" }, "carrierHRF": { "type": "string" }, "entryType": { "type": "string", "enum": ["barcode", "rfid", "manual", "card", "self-reported", "unknown"] } } } },
    "status": { "type": "string", "enum": ["active", "inactive", "entered-in-error", "unknown"] },
    "statusReason": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "distinctIdentifier": { "type": "string" },
    "manufacturer": { "type": "string" },
    "manufactureDate": { "type": "string" },
    "expirationDate": { "type": "string" },
    "lotNumber": { "type": "string" },
    "serialNumber": { "type": "string" },
    "deviceName": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string", "enum": ["udi-label-name", "user-friendly-name", "patient-reported-name", "manufacturer-name", "model-name", "other"] } } } },
    "modelNumber": { "type": "string" },
    "partNumber": { "type": "string" },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "specialization": { "type": "array", "items": { "type": "object", "properties": { "systemType": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "version": { "type": "string" } } } },
    "version": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "component": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } }, "value": { "type": "string" } } } },
    "property": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "valueQuantity": { "type": "array", "items": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } } }, "valueCode": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } } } } },
    "patient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "owner": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } },
    "location": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "url": { "type": "string" },
    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } },
    "safety": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "parent": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }
  }
}
