{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/MolecularSequence",
  "description": "Raw data describing a biological sequence.",
  "type": "object",
  "required": ["resourceType", "coordinateSystem"],
  "properties": {
    "resourceType": { "const": "MolecularSequence" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "type": { "type": "string", "enum": ["aa", "dna", "rna"] },
    "coordinateSystem": { "type": "integer" },
    "patient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "specimen": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "device": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "performer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "quantity": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } },
    "referenceSeq": { "type": "object", "properties": { "chromosome": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "genomeBuild": { "type": "string" }, "orientation": { "type": "string", "enum": ["sense", "antisense"] }, "referenceSeqId": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "referenceSeqPointer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "referenceSeqString": { "type": "string" }, "strand": { "type": "string", "enum": ["watson", "crick"] }, "windowStart": { "type": "integer" }, "windowEnd": { "type": "integer" } } },
    "variant": { "type": "array", "items": { "type": "object", "properties": { "start": { "type": "integer" }, "end": { "type": "integer" }, "observedAllele": { "type": "string" }, "referenceAllele": { "type": "string" }, "cigar": { "type": "string" }, "variantPointer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } },
    "observedSeq": { "type": "string" },
    "quality": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["indel", "snp", "unknown"] }, "standardSequence": { "type": "object" }, "start": { "type": "integer" }, "end": { "type": "integer" }, "score": { "type": "object" }, "method": { "type": "object" }, "truthTP": { "type": "number" }, "queryTP": { "type": "number" }, "truthFN": { "type": "number" }, "queryFP": { "type": "number" }, "gtFP": { "type": "number" }, "precision": { "type": "number" }, "recall": { "type": "number" }, "fScore": { "type": "number" }, "roc": { "type": "object" } } } },
    "readCoverage": { "type": "integer" },
    "repository": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["directlink", "openapi", "login", "oauth", "other"] }, "url": { "type": "string" }, "name": { "type": "string" }, "datasetId": { "type": "string" }, "variantsetId": { "type": "string" }, "readsetId": { "type": "string" } } } },
    "pointer": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "structureVariant": { "type": "array", "items": { "type": "object", "properties": { "variantType": { "type": "object" }, "exact": { "type": "boolean" }, "length": { "type": "integer" }, "outer": { "type": "object" }, "inner": { "type": "object" } } } }
  }
}
