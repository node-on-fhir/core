{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/MedicationKnowledge",
  "description": "Information about a medication that is used to support knowledge.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "MedicationKnowledge" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "code": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "status": { "type": "string", "enum": ["active", "inactive", "entered-in-error"] },
    "manufacturer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "doseForm": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "amount": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } },
    "synonym": { "type": "array", "items": { "type": "string" } },
    "relatedMedicationKnowledge": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "reference": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } } },
    "associatedMedication": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "productType": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "monograph": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "source": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } },
    "ingredient": { "type": "array", "items": { "type": "object", "properties": { "itemCodeableConcept": { "type": "object" }, "itemReference": { "type": "object" }, "isActive": { "type": "boolean" }, "strength": { "type": "object" } } } },
    "preparationInstruction": { "type": "string" },
    "intendedRoute": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "cost": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "source": { "type": "string" }, "cost": { "type": "object" } } } },
    "monitoringProgram": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "name": { "type": "string" } } } },
    "administrationGuidelines": { "type": "array", "items": { "type": "object", "properties": { "dosage": { "type": "array", "items": { "type": "object" } }, "indicationCodeableConcept": { "type": "object" }, "indicationReference": { "type": "object" }, "patientCharacteristics": { "type": "array", "items": { "type": "object" } } } } },
    "medicineClassification": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "classification": { "type": "array", "items": { "type": "object" } } } } },
    "packaging": { "type": "object", "properties": { "type": { "type": "object" }, "quantity": { "type": "object" } } },
    "drugCharacteristic": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "valueCodeableConcept": { "type": "object" }, "valueString": { "type": "string" }, "valueQuantity": { "type": "object" }, "valueBase64Binary": { "type": "string" } } } },
    "contraindication": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "regulatory": { "type": "array", "items": { "type": "object", "properties": { "regulatoryAuthority": { "type": "object" }, "substitution": { "type": "array", "items": { "type": "object" } }, "schedule": { "type": "array", "items": { "type": "object" } }, "maxDispense": { "type": "object" } } } },
    "kinetics": { "type": "array", "items": { "type": "object", "properties": { "areaUnderCurve": { "type": "array", "items": { "type": "object" } }, "lethalDose50": { "type": "array", "items": { "type": "object" } }, "halfLifePeriod": { "type": "object" } } } }
  }
}
