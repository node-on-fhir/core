    "item": { "type": "array", "items": { "type": "object", "properties": { "linkId": { "type": "string" }, "definition": { "type": "string" }, "code": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "prefix": { "type": "string" }, "text": { "type": "string" }, "type": { "type": "string", "enum": ["group", "display", "boolean", "decimal", "integer", "date", "dateTime", "time", "string", "text", "url", "choice", "open-choice", "attachment", "reference", "quantity"] }, "enableWhen": { "type": "array", "items": { "type": "object", "properties": { "question": { "type": "string" }, "operator": { "type": "string", "enum": ["exists", "=", "!=", ">", "<", ">=", "<="] }, "answerBoolean": { "type": "boolean" }, "answerDecimal": { "type": "number" }, "answerInteger": { "type": "integer" }, "answerDate": { "type": "string" }, "answerDateTime": { "type": "string" }, "answerTime": { "type": "string" }, "answerString": { "type": "string" }, "answerCoding": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "answerQuantity": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } }, "answerReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } }, "enableBehavior": { "type": "string", "enum": ["all", "any"] }, "required": { "type": "boolean" }, "repeats": { "type": "boolean" }, "readOnly": { "type": "boolean" }, "maxLength": { "type": "integer" }, "answerValueSet": { "type": "string" }, "answerOption": { "type": "array", "items": { "type": "object", "properties": { "valueInteger": { "type": "integer" }, "valueDate": { "type": "string" }, "valueTime": { "type": "string" }, "valueString": { "type": "string" }, "valueCoding": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "valueReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "initialSelected": { "type": "boolean" } } } }, "initial": { "type": "array", "items": { "type": "object", "properties": { "valueBoolean": { "type": "boolean" }, "valueDecimal": { "type": "number" }, "valueInteger": { "type": "integer" }, "valueDate": { "type": "string" }, "valueDateTime": { "type": "string" }, "valueTime": { "type": "string" }, "valueString": { "type": "string" }, "valueUri": { "type": "string" }, "valueAttachment": { "type": "object" }, "valueCoding": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "valueQuantity": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } }, "valueReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } }, "item": { "type": "array", "items": { "type": "object" } } } } }
  }
