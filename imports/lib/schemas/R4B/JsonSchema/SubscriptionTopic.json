{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/SubscriptionTopic",
  "description": "Describes a stream of resource state changes identified by trigger criteria and annotated with labels useful to filter projections from this topic.",
  "type": "object",
  "required": ["resourceType", "status", "url"],
  "properties": {
    "resourceType": { "const": "SubscriptionTopic" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "derivedFrom": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "copyright": { "type": "string" },
    "approvalDate": { "type": "string" },
    "lastReviewDate": { "type": "string" },
    "effectivePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "resourceTrigger": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "resource": { "type": "string" }, "supportedInteraction": { "type": "array", "items": { "type": "string" } }, "queryCriteria": { "type": "object", "properties": { "previous": { "type": "string" }, "resultForCreate": { "type": "string" }, "current": { "type": "string" }, "resultForDelete": { "type": "string" }, "requireBoth": { "type": "boolean" } } }, "fhirPathCriteria": { "type": "string" } } } },
    "eventTrigger": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "event": { "type": "object" }, "resource": { "type": "string" } } } },
    "canFilterBy": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "resource": { "type": "string" }, "filterParameter": { "type": "string" }, "filterDefinition": { "type": "string" }, "modifier": { "type": "array", "items": { "type": "string" } } } } },
    "notificationShape": { "type": "array", "items": { "type": "object", "properties": { "resource": { "type": "string" }, "include": { "type": "array", "items": { "type": "string" } }, "revInclude": { "type": "array", "items": { "type": "string" } } } } }
  }
}
