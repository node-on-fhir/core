    "communicationRequest": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "insurance": { "type": "array", "items": { "type": "object", "properties": { "sequence": { "type": "integer" }, "focal": { "type": "boolean" }, "coverage": { "type": "object" }, "businessArrangement": { "type": "string" }, "claimResponse": { "type": "object" } } } },
