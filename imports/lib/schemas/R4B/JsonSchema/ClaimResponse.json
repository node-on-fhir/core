    "total": { "type": "array", "items": { "type": "object", "properties": { "category": { "type": "object" }, "amount": { "type": "object" } } } },
    "payment": { "type": "object", "properties": { "type": { "type": "object" }, "adjustment": { "type": "object" }, "adjustmentReason": { "type": "object" }, "date": { "type": "string" }, "amount": { "type": "object" }, "identifier": { "type": "object" } } },
    "fundsReserve": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "formCode": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "form": { "type": "object" },
