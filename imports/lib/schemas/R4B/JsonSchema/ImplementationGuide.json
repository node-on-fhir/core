{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/ImplementationGuide",
  "description": "A set of rules of how a particular interoperability or standards problem is solved - typically through the use of FHIR resources.",
  "type": "object",
  "required": ["resourceType", "status", "url", "name", "packageId", "fhirVersion"],
  "properties": {
    "resourceType": { "const": "ImplementationGuide" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "copyright": { "type": "string" },
    "packageId": { "type": "string" },
    "license": { "type": "string" },
    "fhirVersion": { "type": "array", "items": { "type": "string" } },
    "dependsOn": { "type": "array", "items": { "type": "object", "properties": { "uri": { "type": "string" }, "packageId": { "type": "string" }, "version": { "type": "string" } } } },
    "global": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string" }, "profile": { "type": "string" } } } },
    "definition": { "type": "object", "properties": { "grouping": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" } } } }, "resource": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "object" }, "fhirVersion": { "type": "array", "items": { "type": "string" } }, "name": { "type": "string" }, "description": { "type": "string" }, "exampleBoolean": { "type": "boolean" }, "exampleCanonical": { "type": "string" }, "groupingId": { "type": "string" } } } }, "page": { "type": "object", "properties": { "nameUrl": { "type": "string" }, "nameReference": { "type": "object" }, "title": { "type": "string" }, "generation": { "type": "string" }, "page": { "type": "array", "items": { "type": "object" } } } }, "parameter": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "string" }, "value": { "type": "string" } } } }, "template": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "string" }, "source": { "type": "string" }, "scope": { "type": "string" } } } } } },
    "manifest": { "type": "object", "properties": { "rendering": { "type": "string" }, "resource": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "object" }, "exampleBoolean": { "type": "boolean" }, "exampleCanonical": { "type": "string" }, "relativePath": { "type": "string" } } } }, "page": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "title": { "type": "string" }, "anchor": { "type": "array", "items": { "type": "string" } } } } }, "image": { "type": "array", "items": { "type": "string" } }, "other": { "type": "array", "items": { "type": "string" } } } }
  }
}
