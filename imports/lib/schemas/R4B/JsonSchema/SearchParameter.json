{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/SearchParameter",
  "description": "A search parameter that defines a named search item that can be used to search/filter on a resource.",
  "type": "object",
  "required": ["resourceType", "url", "name", "status", "description", "code", "base", "type"],
  "properties": {
    "resourceType": { "const": "SearchParameter" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "derivedFrom": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "valueCodeableConcept": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } } } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "code": { "type": "string" },
    "base": { "type": "array", "items": { "type": "string" } },
    "type": { "type": "string", "enum": ["number", "date", "string", "token", "reference", "composite", "quantity", "uri", "special"] },
    "expression": { "type": "string" },
    "xpath": { "type": "string" },
    "xpathUsage": { "type": "string", "enum": ["normal", "phonetic", "nearby", "distance", "other"] },
    "target": { "type": "array", "items": { "type": "string" } },
    "multipleOr": { "type": "boolean" },
    "multipleAnd": { "type": "boolean" },
    "comparator": { "type": "array", "items": { "type": "string", "enum": ["eq", "ne", "gt", "lt", "ge", "le", "sa", "eb", "ap"] } },
    "modifier": { "type": "array", "items": { "type": "string", "enum": ["missing", "exact", "contains", "not", "text", "in", "not-in", "below", "above", "type", "identifier", "ofType"] } },
    "chain": { "type": "array", "items": { "type": "string" } },
    "component": { "type": "array", "items": { "type": "object", "properties": { "definition": { "type": "string" }, "expression": { "type": "string" } } } }
  }
}
