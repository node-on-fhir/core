{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/Citation",
  "description": "The Citation Resource enables reference to any knowledge artifact for purposes of identification and attribution.",
  "type": "object",
  "required": ["resourceType", "status"],
  "properties": {
    "resourceType": { "const": "Citation" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "copyright": { "type": "string" },
    "approvalDate": { "type": "string" },
    "lastReviewDate": { "type": "string" },
    "effectivePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "author": { "type": "array", "items": { "type": "object" } },
    "editor": { "type": "array", "items": { "type": "object" } },
    "reviewer": { "type": "array", "items": { "type": "object" } },
    "endorser": { "type": "array", "items": { "type": "object" } },
    "summary": { "type": "array", "items": { "type": "object", "properties": { "style": { "type": "object" }, "text": { "type": "string" } } } },
    "classification": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "classifier": { "type": "array", "items": { "type": "object" } } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } },
    "currentState": { "type": "array", "items": { "type": "object" } },
    "statusDate": { "type": "array", "items": { "type": "object", "properties": { "activity": { "type": "object" }, "actual": { "type": "boolean" }, "period": { "type": "object" } } } },
    "relatesTo": { "type": "array", "items": { "type": "object", "properties": { "relationshipType": { "type": "object" }, "targetClassifier": { "type": "array", "items": { "type": "object" } }, "targetUri": { "type": "string" }, "targetIdentifier": { "type": "object" }, "targetReference": { "type": "object" }, "targetAttachment": { "type": "object" } } } },
    "citedArtifact": { "type": "object", "properties": { "identifier": { "type": "array", "items": { "type": "object" } }, "relatedIdentifier": { "type": "array", "items": { "type": "object" } }, "dateAccessed": { "type": "string" }, "version": { "type": "object" }, "currentState": { "type": "array", "items": { "type": "object" } }, "statusDate": { "type": "array", "items": { "type": "object" } }, "title": { "type": "array", "items": { "type": "object" } }, "abstract": { "type": "array", "items": { "type": "object" } }, "part": { "type": "object" }, "relatesTo": { "type": "array", "items": { "type": "object" } }, "publicationForm": { "type": "array", "items": { "type": "object" } }, "webLocation": { "type": "array", "items": { "type": "object" } }, "classification": { "type": "array", "items": { "type": "object" } }, "contributorship": { "type": "object" }, "note": { "type": "array", "items": { "type": "object" } } } }
  }
}
