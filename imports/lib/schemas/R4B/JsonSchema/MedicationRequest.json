    "medicationReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "subject": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "encounter": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "supportingInformation": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "authoredOn": { "type": "string" },
    "requester": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "performer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
