    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } },
    "dosageInstruction": { "type": "array", "items": { "type": "object", "properties": { "sequence": { "type": "integer" }, "text": { "type": "string" }, "additionalInstruction": { "type": "array", "items": { "type": "object" } }, "patientInstruction": { "type": "string" }, "timing": { "type": "object" }, "asNeededBoolean": { "type": "boolean" }, "asNeededCodeableConcept": { "type": "object" }, "site": { "type": "object" }, "route": { "type": "object" }, "method": { "type": "object" }, "doseAndRate": { "type": "array", "items": { "type": "object" } }, "maxDosePerPeriod": { "type": "object" }, "maxDosePerAdministration": { "type": "object" }, "maxDosePerLifetime": { "type": "object" } } } },
    "dispenseRequest": { "type": "object", "properties": { "initialFill": { "type": "object", "properties": { "quantity": { "type": "object" }, "duration": { "type": "object" } } }, "dispenseInterval": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } }, "validityPeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } }, "numberOfRepeatsAllowed": { "type": "integer" }, "quantity": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } }, "expectedSupplyDuration": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } }, "performer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } },
    "substitution": { "type": "object", "properties": { "allowedBoolean": { "type": "boolean" }, "allowedCodeableConcept": { "type": "object" }, "reason": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } } },
    "priorPrescription": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "detectedIssue": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "eventHistory": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } }
  }
}
