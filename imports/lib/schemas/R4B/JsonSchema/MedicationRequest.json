    "status": { "type": "string", "enum": ["active", "on-hold", "cancelled", "completed", "entered-in-error", "stopped", "draft", "unknown"] },
    "statusReason": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "intent": { "type": "string", "enum": ["proposal", "plan", "order", "original-order", "reflex-order", "filler-order", "instance-order", "option"] },
    "category": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "priority": { "type": "string", "enum": ["routine", "urgent", "asap", "stat"] },
    "doNotPerform": { "type": "boolean" },
