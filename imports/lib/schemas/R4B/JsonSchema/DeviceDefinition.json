{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/DeviceDefinition",
  "description": "The characteristics, operational status and capabilities of a medical-related component of a medical device.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "DeviceDefinition" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "udiDeviceIdentifier": { "type": "array", "items": { "type": "object", "properties": { "deviceIdentifier": { "type": "string" }, "issuer": { "type": "string" }, "jurisdiction": { "type": "string" } } } },
    "manufacturerString": { "type": "string" },
    "manufacturerReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "deviceName": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "type": { "type": "string", "enum": ["udi-label-name", "user-friendly-name", "patient-reported-name", "manufacturer-name", "model-name", "other"] } } } },
    "modelNumber": { "type": "string" },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "specialization": { "type": "array", "items": { "type": "object", "properties": { "systemType": { "type": "string" }, "version": { "type": "string" } } } },
    "version": { "type": "array", "items": { "type": "string" } },
    "safety": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "shelfLifeStorage": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object" }, "periodDuration": { "type": "object" }, "periodString": { "type": "string" }, "specialPrecautionsForStorage": { "type": "array", "items": { "type": "object" } } } } },
    "physicalCharacteristics": { "type": "object", "properties": { "height": { "type": "object" }, "width": { "type": "object" }, "depth": { "type": "object" }, "weight": { "type": "object" }, "nominalVolume": { "type": "object" }, "externalDiameter": { "type": "object" }, "shape": { "type": "string" }, "color": { "type": "array", "items": { "type": "string" } }, "image": { "type": "array", "items": { "type": "object" } } } },
    "languageCode": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "capability": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "description": { "type": "array", "items": { "type": "object" } } } } },
    "property": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "valueQuantity": { "type": "array", "items": { "type": "object" } }, "valueCode": { "type": "array", "items": { "type": "object" } } } } },
    "owner": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } },
    "url": { "type": "string" },
    "onlineInformation": { "type": "string" },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } },
    "quantity": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } },
    "parentDevice": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "material": { "type": "array", "items": { "type": "object", "properties": { "substance": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "alternate": { "type": "boolean" }, "allergenicIndicator": { "type": "boolean" } } } }
  }
}
