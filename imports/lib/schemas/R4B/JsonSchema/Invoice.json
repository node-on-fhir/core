{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/Invoice",
  "description": "Invoice containing collected ChargeItems from an Account with calculated individual and total price for Billing purpose.",
  "type": "object",
  "required": ["resourceType", "status"],
  "properties": {
    "resourceType": { "const": "Invoice" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "status": { "type": "string", "enum": ["draft", "issued", "balanced", "cancelled", "entered-in-error"] },
    "cancelledReason": { "type": "string" },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "subject": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "recipient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "date": { "type": "string" },
    "participant": { "type": "array", "items": { "type": "object", "properties": { "role": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "actor": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } },
    "issuer": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "account": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "lineItem": { "type": "array", "items": { "type": "object", "properties": { "sequence": { "type": "integer" }, "chargeItemReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "chargeItemCodeableConcept": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "priceComponent": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["base", "surcharge", "deduction", "discount", "tax", "informational"] }, "code": { "type": "object" }, "factor": { "type": "number" }, "amount": { "type": "object" } } } } } } },
    "totalPriceComponent": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string" }, "code": { "type": "object" }, "factor": { "type": "number" }, "amount": { "type": "object" } } } },
    "totalNet": { "type": "object", "properties": { "value": { "type": "number" }, "currency": { "type": "string" } } },
    "totalGross": { "type": "object", "properties": { "value": { "type": "number" }, "currency": { "type": "string" } } },
    "paymentTerms": { "type": "string" },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } }
  }
}
