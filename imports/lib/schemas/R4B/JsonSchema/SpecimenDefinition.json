{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/SpecimenDefinition",
  "description": "A kind of specimen with associated set of requirements.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "SpecimenDefinition" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } },
    "typeCollected": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "patientPreparation": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "timeAspect": { "type": "string" },
    "collection": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "typeTested": { "type": "array", "items": { "type": "object", "properties": { "isDerived": { "type": "boolean" }, "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "preference": { "type": "string", "enum": ["preferred", "alternate"] }, "container": { "type": "object", "properties": { "material": { "type": "object" }, "type": { "type": "object" }, "cap": { "type": "object" }, "description": { "type": "string" }, "capacity": { "type": "object" }, "minimumVolumeQuantity": { "type": "object" }, "minimumVolumeString": { "type": "string" }, "additive": { "type": "array", "items": { "type": "object" } }, "preparation": { "type": "string" } } }, "requirement": { "type": "string" }, "retentionTime": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } }, "rejectionCriterion": { "type": "array", "items": { "type": "object" } }, "handling": { "type": "array", "items": { "type": "object", "properties": { "temperatureQualifier": { "type": "object" }, "temperatureRange": { "type": "object" }, "maxDuration": { "type": "object" }, "instruction": { "type": "string" } } } } } } }
  }
}
