    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "shortTitle": { "type": "string" },
    "subtitle": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "subjectCodeableConcept": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "subjectReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "description": { "type": "string" },
    "comment": { "type": "array", "items": { "type": "string" } },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "usage": { "type": "string" },
    "copyright": { "type": "string" },
    "approvalDate": { "type": "string" },
    "lastReviewDate": { "type": "string" },
    "effectivePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "topic": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "author": { "type": "array", "items": { "type": "object" } },
    "editor": { "type": "array", "items": { "type": "object" } },
    "reviewer": { "type": "array", "items": { "type": "object" } },
    "endorser": { "type": "array", "items": { "type": "object" } },
    "relatedArtifact": { "type": "array", "items": { "type": "object" } },
    "library": { "type": "array", "items": { "type": "string" } },
    "type": { "type": "string", "enum": ["population", "exposure", "outcome"] },
    "variableType": { "type": "string", "enum": ["dichotomous", "continuous", "descriptive"] },
    "characteristic": { "type": "array", "items": { "type": "object", "properties": { "definitionCodeableConcept": { "type": "object" }, "definitionCanonical": { "type": "string" }, "definitionExpression": { "type": "object" }, "definitionDataRequirement": { "type": "object" }, "usageContext": { "type": "array", "items": { "type": "object" } }, "exclude": { "type": "boolean" }, "unitOfMeasure": { "type": "object" }, "studyEffectiveDescription": { "type": "string" }, "studyEffectiveDateTime": { "type": "string" }, "studyEffectivePeriod": { "type": "object" }, "studyEffectiveDuration": { "type": "object" }, "studyEffectiveTiming": { "type": "object" }, "studyEffectiveTimeFromStart": { "type": "object" }, "studyEffectiveGroupMeasure": { "type": "string" }, "participantEffectiveDescription": { "type": "string" }, "participantEffectiveDateTime": { "type": "string" }, "participantEffectivePeriod": { "type": "object" }, "participantEffectiveDuration": { "type": "object" }, "participantEffectiveTiming": { "type": "object" }, "participantEffectiveTimeFromStart": { "type": "object" }, "participantEffectiveGroupMeasure": { "type": "string" } } } }
  }
}
