{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/TestScript",
  "description": "A structured set of tests against a FHIR server or client implementation to determine compliance against the FHIR specification.",
  "type": "object",
  "required": ["resourceType", "status", "url", "name"],
  "properties": {
    "resourceType": { "const": "TestScript" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "copyright": { "type": "string" },
    "origin": { "type": "array", "items": { "type": "object", "properties": { "index": { "type": "integer" }, "profile": { "type": "object" } } } },
    "destination": { "type": "array", "items": { "type": "object", "properties": { "index": { "type": "integer" }, "profile": { "type": "object" } } } },
    "metadata": { "type": "object", "properties": { "link": { "type": "array", "items": { "type": "object", "properties": { "url": { "type": "string" }, "description": { "type": "string" } } } }, "capability": { "type": "array", "items": { "type": "object", "properties": { "required": { "type": "boolean" }, "validated": { "type": "boolean" }, "description": { "type": "string" }, "origin": { "type": "array", "items": { "type": "integer" } }, "destination": { "type": "integer" }, "link": { "type": "array", "items": { "type": "string" } }, "capabilities": { "type": "string" } } } } } },
    "fixture": { "type": "array", "items": { "type": "object", "properties": { "autocreate": { "type": "boolean" }, "autodelete": { "type": "boolean" }, "resource": { "type": "object" } } } },
    "profile": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "variable": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "defaultValue": { "type": "string" }, "description": { "type": "string" }, "expression": { "type": "string" }, "headerField": { "type": "string" }, "hint": { "type": "string" }, "path": { "type": "string" }, "sourceId": { "type": "string" } } } },
    "setup": { "type": "object", "properties": { "action": { "type": "array", "items": { "type": "object", "properties": { "operation": { "type": "object", "properties": { "type": { "type": "object" }, "resource": { "type": "string" }, "label": { "type": "string" }, "description": { "type": "string" }, "accept": { "type": "string" }, "contentType": { "type": "string" }, "destination": { "type": "integer" }, "encodeRequestUrl": { "type": "boolean" }, "method": { "type": "string" }, "origin": { "type": "integer" }, "params": { "type": "string" }, "requestHeader": { "type": "array", "items": { "type": "object" } }, "requestId": { "type": "string" }, "responseId": { "type": "string" }, "sourceId": { "type": "string" }, "targetId": { "type": "string" }, "url": { "type": "string" } } }, "assert": { "type": "object", "properties": { "label": { "type": "string" }, "description": { "type": "string" }, "direction": { "type": "string" }, "compareToSourceId": { "type": "string" }, "compareToSourceExpression": { "type": "string" }, "compareToSourcePath": { "type": "string" }, "contentType": { "type": "string" }, "expression": { "type": "string" }, "headerField": { "type": "string" }, "minimumId": { "type": "string" }, "navigationLinks": { "type": "boolean" }, "operator": { "type": "string" }, "path": { "type": "string" }, "requestMethod": { "type": "string" }, "requestURL": { "type": "string" }, "resource": { "type": "string" }, "response": { "type": "string" }, "responseCode": { "type": "string" }, "sourceId": { "type": "string" }, "validateProfileId": { "type": "string" }, "value": { "type": "string" }, "warningOnly": { "type": "boolean" } } } } } } } },
    "test": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" }, "action": { "type": "array", "items": { "type": "object" } } } } },
    "teardown": { "type": "object", "properties": { "action": { "type": "array", "items": { "type": "object", "properties": { "operation": { "type": "object" } } } } } }
  }
}
