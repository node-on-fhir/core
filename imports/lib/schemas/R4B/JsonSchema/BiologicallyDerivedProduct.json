{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/BiologicallyDerivedProduct",
  "description": "A material substance originating from a biological entity intended to be transplanted or infused into another (possibly the same) biological entity.",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "BiologicallyDerivedProduct" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "productCategory": { "type": "string", "enum": ["organ", "tissue", "fluid", "cells", "biologicalAgent"] },
    "productCode": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "status": { "type": "string", "enum": ["available", "unavailable"] },
    "request": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "quantity": { "type": "integer" },
    "parent": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "collection": { "type": "object", "properties": { "collector": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "source": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "collectedDateTime": { "type": "string" }, "collectedPeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } } } },
    "processing": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "procedure": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "additive": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "timeDateTime": { "type": "string" }, "timePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } } } } },
    "manipulation": { "type": "object", "properties": { "description": { "type": "string" }, "timeDateTime": { "type": "string" }, "timePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } } } },
    "storage": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "temperature": { "type": "number" }, "scale": { "type": "string", "enum": ["farenheit", "celsius", "kelvin"] }, "duration": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } } } } }
  }
}
