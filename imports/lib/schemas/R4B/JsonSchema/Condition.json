    "evidence": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } }, "detail": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } }
