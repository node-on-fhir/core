{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/ValueSet",
  "description": "A ValueSet resource instance specifies a set of codes drawn from one or more code systems, intended for use in a particular context.",
  "type": "object",
  "required": ["resourceType", "status"],
  "properties": {
    "resourceType": { "const": "ValueSet" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "valueCodeableConcept": { "type": "object" }, "valueQuantity": { "type": "object" }, "valueRange": { "type": "object" }, "valueReference": { "type": "object" } } } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "immutable": { "type": "boolean" },
    "purpose": { "type": "string" },
    "copyright": { "type": "string" },
    "compose": { "type": "object", "properties": { "lockedDate": { "type": "string" }, "inactive": { "type": "boolean" }, "include": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "version": { "type": "string" }, "concept": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "string" }, "display": { "type": "string" }, "designation": { "type": "array", "items": { "type": "object", "properties": { "language": { "type": "string" }, "use": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "value": { "type": "string" } } } } } } }, "filter": { "type": "array", "items": { "type": "object", "properties": { "property": { "type": "string" }, "op": { "type": "string", "enum": ["=", "is-a", "descendent-of", "is-not-a", "regex", "in", "not-in", "generalizes", "exists"] }, "value": { "type": "string" } } } }, "valueSet": { "type": "array", "items": { "type": "string" } } } } }, "exclude": { "type": "array", "items": { "type": "object" } } } },
    "expansion": { "type": "object", "properties": { "identifier": { "type": "string" }, "timestamp": { "type": "string" }, "total": { "type": "integer" }, "offset": { "type": "integer" }, "parameter": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "valueString": { "type": "string" }, "valueBoolean": { "type": "boolean" }, "valueInteger": { "type": "integer" }, "valueDecimal": { "type": "number" }, "valueUri": { "type": "string" }, "valueCode": { "type": "string" }, "valueDateTime": { "type": "string" } } } }, "contains": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "abstract": { "type": "boolean" }, "inactive": { "type": "boolean" }, "version": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" }, "designation": { "type": "array", "items": { "type": "object" } }, "contains": { "type": "array", "items": { "type": "object" } } } } } } }
  }
}
