{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/BodyStructure",
  "description": "Record details about an anatomical structure. This resource may be used when a coded concept does not provide the necessary detail needed for the use case.",
  "type": "object",
  "required": ["resourceType", "patient"],
  "properties": {
    "resourceType": {
      "const": "BodyStructure"
    },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "description": "Metadata about the resource", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string", "description": "A set of rules under which this content was created" },
    "language": { "type": "string", "description": "Language of the resource content" },
    "text": { "type": "object", "description": "Text summary of the resource", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "description": "Contained, inline Resources", "items": { "type": "object" } },
    "extension": { "type": "array", "description": "Additional content defined by implementations", "items": { "type": "object", "properties": { "url": { "type": "string" }, "valueString": { "type": "string" }, "valueBoolean": { "type": "boolean" }, "valueCode": { "type": "string" } } } },
    "modifierExtension": { "type": "array", "description": "Extensions that cannot be ignored", "items": { "type": "object", "properties": { "url": { "type": "string" }, "valueString": { "type": "string" }, "valueBoolean": { "type": "boolean" }, "valueCode": { "type": "string" } } } },
    "identifier": { "type": "array", "description": "Bodystructure identifier", "items": { "type": "object", "properties": { "use": { "type": "string" }, "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "system": { "type": "string" }, "value": { "type": "string" }, "period": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } }, "assigner": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } } } },
    "active": { "type": "boolean", "description": "Whether this record is in active use" },
    "morphology": {
      "type": "object",
      "description": "Kind of Structure",
      "properties": {
        "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } },
        "text": { "type": "string" }
      }
    },
    "location": {
      "type": "object",
      "description": "Body site",
      "properties": {
        "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } },
        "text": { "type": "string" }
      }
    },
    "locationQualifier": {
      "type": "array",
      "description": "Body site modifier",
      "items": {
        "type": "object",
        "properties": {
          "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } },
          "text": { "type": "string" }
        }
      }
    },
    "description": { "type": "string", "description": "Text description" },
    "image": {
      "type": "array",
      "description": "Attached images",
      "items": {
        "type": "object",
        "properties": {
          "contentType": { "type": "string" },
          "language": { "type": "string" },
          "data": { "type": "string" },
          "url": { "type": "string" },
          "size": { "type": "integer" },
          "hash": { "type": "string" },
          "title": { "type": "string" },
          "creation": { "type": "string" }
        }
      }
    },
    "patient": {
      "type": "object",
      "description": "Who this is about",
      "properties": {
        "reference": { "type": "string" },
        "display": { "type": "string" }
      }
    }
  }
}
