{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/DeviceMetric",
  "description": "Describes a measurement, calculation or setting capability of a medical device.",
  "type": "object",
  "required": ["resourceType", "type", "category"],
  "properties": {
    "resourceType": { "const": "DeviceMetric" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "unit": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "source": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "parent": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "operationalStatus": { "type": "string", "enum": ["on", "off", "standby", "entered-in-error"] },
    "color": { "type": "string", "enum": ["black", "red", "green", "yellow", "blue", "magenta", "cyan", "white"] },
    "category": { "type": "string", "enum": ["measurement", "setting", "calculation", "unspecified"] },
    "measurementPeriod": { "type": "object", "properties": { "event": { "type": "array", "items": { "type": "string" } }, "repeat": { "type": "object" }, "code": { "type": "object" } } },
    "calibration": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["unspecified", "offset", "gain", "two-point"] }, "state": { "type": "string", "enum": ["not-calibrated", "calibration-required", "calibrated", "unspecified"] }, "time": { "type": "string" } } } }
  }
}
