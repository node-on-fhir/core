{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/EpisodeOfCare",
  "description": "An association between a patient and an organization / healthcare provider(s) during which time encounters may occur.",
  "type": "object",
  "required": ["resourceType", "status", "patient"],
  "properties": {
    "resourceType": { "const": "EpisodeOfCare" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "status": { "type": "string", "enum": ["planned", "waitlist", "active", "onhold", "finished", "cancelled", "entered-in-error"] },
    "statusHistory": { "type": "array", "items": { "type": "object", "properties": { "status": { "type": "string", "enum": ["planned", "waitlist", "active", "onhold", "finished", "cancelled", "entered-in-error"] }, "period": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } } } } },
    "type": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "diagnosis": { "type": "array", "items": { "type": "object", "properties": { "condition": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "role": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "rank": { "type": "integer" } } } },
    "patient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "managingOrganization": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "period": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "referralRequest": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "careManager": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "team": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "account": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } }
  }
}
