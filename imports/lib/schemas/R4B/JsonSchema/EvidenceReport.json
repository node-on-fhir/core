{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/EvidenceReport",
  "description": "The EvidenceReport Resource is a specialized container for a collection of resources and codable concepts, adapted to support compositions of Evidence, EvidenceVariable, and Citation resources and related concepts.",
  "type": "object",
  "required": ["resourceType", "status"],
  "properties": {
    "resourceType": { "const": "EvidenceReport" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "useContext": { "type": "array", "items": { "type": "object" } },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "relatedIdentifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "citeAsReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "citeAsMarkdown": { "type": "string" },
    "type": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "authorReference": { "type": "object" }, "authorString": { "type": "string" }, "time": { "type": "string" }, "text": { "type": "string" } } } },
    "relatedArtifact": { "type": "array", "items": { "type": "object" } },
    "subject": { "type": "object", "properties": { "characteristic": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object" }, "valueReference": { "type": "object" }, "valueCodeableConcept": { "type": "object" }, "valueBoolean": { "type": "boolean" }, "valueQuantity": { "type": "object" }, "valueRange": { "type": "object" }, "exclude": { "type": "boolean" }, "period": { "type": "object" } } } }, "note": { "type": "array", "items": { "type": "object" } } } },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object" } } } } },
    "author": { "type": "array", "items": { "type": "object" } },
    "editor": { "type": "array", "items": { "type": "object" } },
    "reviewer": { "type": "array", "items": { "type": "object" } },
    "endorser": { "type": "array", "items": { "type": "object" } },
    "relatesTo": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "string", "enum": ["replaces", "amends", "appends", "transforms", "replacedWith", "amendedWith", "appendedWith", "transformedWith"] }, "targetIdentifier": { "type": "object" }, "targetReference": { "type": "object" } } } },
    "section": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "focus": { "type": "object" }, "focusReference": { "type": "object" }, "author": { "type": "array", "items": { "type": "object" } }, "text": { "type": "object" }, "mode": { "type": "string" }, "orderedBy": { "type": "object" }, "entryClassifier": { "type": "array", "items": { "type": "object" } }, "entryReference": { "type": "array", "items": { "type": "object" } }, "entryQuantity": { "type": "array", "items": { "type": "object" } }, "emptyReason": { "type": "object" }, "section": { "type": "array", "items": { "type": "object" } } } } }
  }
}
