    "lastReviewDate": { "type": "string" },
    "effectivePeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
    "author": { "type": "array", "items": { "type": "object" } },
    "editor": { "type": "array", "items": { "type": "object" } },
    "reviewer": { "type": "array", "items": { "type": "object" } },
    "endorser": { "type": "array", "items": { "type": "object" } },
    "relatedArtifact": { "type": "array", "items": { "type": "object" } },
    "actual": { "type": "boolean" },
    "characteristicCombination": { "type": "string", "enum": ["all-of", "any-of", "at-least", "at-most", "statistical", "net-effect", "dataset"] },
    "characteristic": { "type": "array", "items": { "type": "object", "properties": { "description": { "type": "string" }, "definitionReference": { "type": "object" }, "definitionCanonical": { "type": "string" }, "definitionCodeableConcept": { "type": "object" }, "definitionExpression": { "type": "object" }, "definitionId": { "type": "string" }, "definitionByTypeAndValue": { "type": "object", "properties": { "type": { "type": "object" }, "valueCodeableConcept": { "type": "object" }, "valueBoolean": { "type": "boolean" }, "valueQuantity": { "type": "object" }, "valueRange": { "type": "object" }, "valueReference": { "type": "object" }, "valueId": { "type": "string" } } }, "definitionByCombination": { "type": "object", "properties": { "code": { "type": "string" }, "threshold": { "type": "integer" }, "characteristic": { "type": "array", "items": { "type": "object" } } } }, "method": { "type": "array", "items": { "type": "object" } }, "device": { "type": "object" }, "exclude": { "type": "boolean" }, "timeFromStart": { "type": "object", "properties": { "description": { "type": "string" }, "quantity": { "type": "object" }, "range": { "type": "object" }, "note": { "type": "array", "items": { "type": "object" } } } }, "groupMeasure": { "type": "string", "enum": ["mean", "median", "mean-of-mean", "mean-of-median", "median-of-mean", "median-of-median"] } } } },
    "handling": { "type": "string", "enum": ["continuous", "dichotomous", "ordinal", "polychotomous"] },
    "category": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "valueCodeableConcept": { "type": "object" }, "valueQuantity": { "type": "object" }, "valueRange": { "type": "object" } } } }
  }
