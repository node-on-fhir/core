    "derivedFrom": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "reasonCode": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "reasonReference": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } },
    "dosage": { "type": "array", "items": { "type": "object", "properties": { "sequence": { "type": "integer" }, "text": { "type": "string" }, "additionalInstruction": { "type": "array", "items": { "type": "object" } }, "patientInstruction": { "type": "string" }, "timing": { "type": "object" }, "asNeededBoolean": { "type": "boolean" }, "asNeededCodeableConcept": { "type": "object" }, "site": { "type": "object" }, "route": { "type": "object" }, "method": { "type": "object" }, "doseAndRate": { "type": "array", "items": { "type": "object" } }, "maxDosePerPeriod": { "type": "object" }, "maxDosePerAdministration": { "type": "object" }, "maxDosePerLifetime": { "type": "object" } } } }
  }
