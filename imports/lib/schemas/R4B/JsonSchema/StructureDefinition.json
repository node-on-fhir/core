{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "id": "http://hl7.org/fhir/json-schema/StructureDefinition",
  "description": "A definition of a FHIR structure. This resource is used to describe the underlying resources, data types defined in FHIR, and also for describing extensions and constraints on resources and data types.",
  "type": "object",
  "required": ["resourceType", "url", "name", "status", "kind", "abstract", "type"],
  "properties": {
    "resourceType": { "const": "StructureDefinition" },
    "id": { "type": "string", "description": "Logical id of this artifact" },
    "_id": { "type": "string", "description": "MongoDB primary key" },
    "meta": { "type": "object", "properties": { "versionId": { "type": "string" }, "lastUpdated": { "type": "string" }, "source": { "type": "string" }, "profile": { "type": "array", "items": { "type": "string" } }, "security": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "tag": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } } } },
    "implicitRules": { "type": "string" },
    "language": { "type": "string" },
    "text": { "type": "object", "properties": { "status": { "type": "string" }, "div": { "type": "string" } } },
    "contained": { "type": "array", "items": { "type": "object" } },
    "extension": { "type": "array", "items": { "type": "object" } },
    "modifierExtension": { "type": "array", "items": { "type": "object" } },
    "url": { "type": "string" },
    "identifier": { "type": "array", "items": { "type": "object", "properties": { "use": { "type": "string" }, "system": { "type": "string" }, "value": { "type": "string" } } } },
    "version": { "type": "string" },
    "name": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "retired", "unknown"] },
    "experimental": { "type": "boolean" },
    "date": { "type": "string" },
    "publisher": { "type": "string" },
    "contact": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "telecom": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "value": { "type": "string" }, "use": { "type": "string" } } } } } } },
    "description": { "type": "string" },
    "useContext": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } }, "valueCodeableConcept": { "type": "object" }, "valueQuantity": { "type": "object" }, "valueRange": { "type": "object" }, "valueReference": { "type": "object" } } } },
    "jurisdiction": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "purpose": { "type": "string" },
    "copyright": { "type": "string" },
    "keyword": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } },
    "fhirVersion": { "type": "string" },
    "mapping": { "type": "array", "items": { "type": "object", "properties": { "identity": { "type": "string" }, "uri": { "type": "string" }, "name": { "type": "string" }, "comment": { "type": "string" } } } },
    "kind": { "type": "string", "enum": ["primitive-type", "complex-type", "resource", "logical"] },
    "abstract": { "type": "boolean" },
    "context": { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string", "enum": ["fhirpath", "element", "extension"] }, "expression": { "type": "string" } } } },
    "contextInvariant": { "type": "array", "items": { "type": "string" } },
    "type": { "type": "string" },
    "baseDefinition": { "type": "string" },
    "derivation": { "type": "string", "enum": ["specialization", "constraint"] },
    "snapshot": { "type": "object", "properties": { "element": { "type": "array", "items": { "type": "object", "properties": { "id": { "type": "string" }, "path": { "type": "string" }, "sliceName": { "type": "string" }, "sliceIsConstraining": { "type": "boolean" }, "label": { "type": "string" }, "code": { "type": "array", "items": { "type": "object" } }, "slicing": { "type": "object" }, "short": { "type": "string" }, "definition": { "type": "string" }, "comment": { "type": "string" }, "requirements": { "type": "string" }, "alias": { "type": "array", "items": { "type": "string" } }, "min": { "type": "integer" }, "max": { "type": "string" }, "base": { "type": "object" }, "contentReference": { "type": "string" }, "type": { "type": "array", "items": { "type": "object" } }, "defaultValue": { "type": "object" }, "meaningWhenMissing": { "type": "string" }, "orderMeaning": { "type": "string" }, "fixed": { "type": "object" }, "pattern": { "type": "object" }, "example": { "type": "array", "items": { "type": "object" } }, "minValue": { "type": "object" }, "maxValue": { "type": "object" }, "maxLength": { "type": "integer" }, "condition": { "type": "array", "items": { "type": "string" } }, "constraint": { "type": "array", "items": { "type": "object" } }, "mustSupport": { "type": "boolean" }, "isModifier": { "type": "boolean" }, "isModifierReason": { "type": "string" }, "isSummary": { "type": "boolean" }, "binding": { "type": "object" }, "mapping": { "type": "array", "items": { "type": "object" } } } } } } },
    "differential": { "type": "object", "properties": { "element": { "type": "array", "items": { "type": "object" } } } }
  }
}
