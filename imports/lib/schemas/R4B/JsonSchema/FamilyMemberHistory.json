    "ageString": { "type": "string" },
    "estimatedAge": { "type": "boolean" },
    "deceasedBoolean": { "type": "boolean" },
    "deceasedAge": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } },
    "deceasedRange": { "type": "object", "properties": { "low": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } }, "high": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" } } } } },
    "deceasedDate": { "type": "string" },
    "deceasedString": { "type": "string" },
    "reasonCode": { "type": "array", "items": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } } },
    "reasonReference": { "type": "array", "items": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } } },
    "note": { "type": "array", "items": { "type": "object", "properties": { "text": { "type": "string" }, "time": { "type": "string" }, "authorReference": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } }, "authorString": { "type": "string" } } } },
    "condition": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "outcome": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } }, "contributedToDeath": { "type": "boolean" }, "onsetAge": { "type": "object", "properties": { "value": { "type": "number" }, "unit": { "type": "string" }, "system": { "type": "string" }, "code": { "type": "string" } } }, "onsetRange": { "type": "object" }, "onsetPeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } }, "onsetString": { "type": "string" }, "note": { "type": "array", "items": { "type": "object" } } } } }
  }
