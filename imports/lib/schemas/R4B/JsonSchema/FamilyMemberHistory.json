    "patient": { "type": "object", "properties": { "reference": { "type": "string" }, "display": { "type": "string" } } },
    "date": { "type": "string" },
    "name": { "type": "string" },
    "relationship": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "sex": { "type": "object", "properties": { "coding": { "type": "array", "items": { "type": "object", "properties": { "system": { "type": "string" }, "code": { "type": "string" }, "display": { "type": "string" } } } }, "text": { "type": "string" } } },
    "bornPeriod": { "type": "object", "properties": { "start": { "type": "string" }, "end": { "type": "string" } } },
