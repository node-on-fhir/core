{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Hand-written app-internal schema for the OAuthClients collection, transcribed 2026-07 from the retired SimpleSchema (imports/lib/schemas/SimpleSchemas/OAuthClients.js). Date-typed SimpleSchema fields are strings here because validation runs on a JSON-cloned copy (Date -> ISO string).",
  "type": "object",
  "required": ["resourceType"],
  "properties": {
    "resourceType": { "const": "OAuthClient" },
    "_id": { "type": "string" },
    "software_statement": { "type": "string" },
    "iss": { "type": "string" },
    "sub": { "type": "string" },
    "aud": { "type": "string" },
    "iat": { "type": "number" },
    "exp": { "type": "number" },
    "jti": { "type": "string" },
    "client_name": { "type": "string" },
    "client_id": { "type": "string" },
    "client_secret": { "type": "string" },
    "tos_uri": { "type": "string" },
    "token_endpoint_auth_method": { "type": "string" },
    "grant_types": { "type": "array", "items": { "type": "string" } },
    "error": { "type": "string" },
    "description": { "type": "string" },
    "created_at": { "type": "string" },
    "authorization_code": { "type": "string" },
    "verified": { "type": "boolean" },
    "redirect_uris": { "type": "array", "items": { "type": "string" } },
    "scope": { "type": "string" },
    "access_token": { "type": "string" },
    "access_token_created_at": { "type": "string" },
    "response_types": { "type": "array", "items": { "type": "string" } },
    "jwks_uri": { "type": "string" },
    "jwks": { "type": "object" },
    "launch_uri": { "type": "string" },
    "pkce_enabled": { "type": "boolean" },
    "pkce_method": { "type": "string", "enum": ["S256", "plain"] },
    "auth_request_method": { "type": "string", "enum": ["GET", "POST"] },
    "patient_id": { "type": "string" },
    "encounter_id": { "type": "string" },
    "launch_type": { "type": "string", "enum": ["ehr", "standalone"] },
    "launch_context": { "type": "string" },
    "code_challenge": { "type": "string" },
    "code_challenge_method": { "type": "string", "enum": ["S256", "plain"] },
    "refresh_token": { "type": "string" },
    "requested_scope": { "type": "string" },
    "user_id": { "type": "string" },
    "authorization_expires_at": { "type": "string" },
    "revoked_at": { "type": "string" },
    "revoked_by": { "type": "string" },
    "session_duration_minutes": { "type": "number" }
  }
}
