{
  "name": "meteor-app",
  "private": true,
  "workspaces": [
    "core/*",
    "extensions/*",
    "npmPackages/*",
    "extensions/merkalis/kastoria-core/block-store",
    "extensions/merkalis/kastoria-core/block-utils",
    "extensions/merkalis/kastoria-core/cbor",
    "extensions/merkalis/kastoria-core/changelog",
